#!/bin/sh
# Pre-commit hook: prevent secrets from being committed
# Activate: git config core.hooksPath .githooks

echo "🔍 Checking for secrets in staged files..."

# Patterns that look like real secrets (not placeholders)
SECRET_PATTERNS='(JWT_SECRET|DATABASE_URL|ADMIN_INITIAL_PASSWORD|API_KEY|SECRET_KEY)'

# Check if any staged .env file (not .env.example) is being committed
STAGED_ENV=$(git diff --cached --name-only | grep -E '\.env$' || true)
if [ -n "$STAGED_ENV" ]; then
  echo "❌ ERROR: Attempting to commit .env files!"
  echo "   Files: $STAGED_ENV"
  echo "   Remove them with: git rm --cached <file>"
  exit 1
fi

# Check for real database URLs (containing actual credentials, not placeholders)
STAGED_FILES=$(git diff --cached --name-only)
for FILE in $STAGED_FILES; do
  if [ ! -f "$FILE" ]; then continue; fi
  # Skip the hook itself (contains example patterns)
  if [ "$FILE" = ".githooks/pre-commit" ]; then continue; fi

  CONTENT=$(git diff --cached "$FILE" | grep '^\+' | grep -v '^+++')

  # Check for postgresql:// with actual password pattern (not placeholder)
  DB_URL=$(echo "$CONTENT" | grep -E 'postgresql://[^:]+:[^@]+@' || true)
  if [ -n "$DB_URL" ]; then
    # Allow placeholders like 'user:password@host' or 'your-password'
    DB_REAL=$(echo "$DB_URL" | grep -v 'user:password@' | grep -v 'your-strong' | grep -v 'replace-with' || true)
    if [ -n "$DB_REAL" ]; then
      echo "❌ ERROR: Possible real DATABASE_URL in $FILE"
      echo "   $DB_REAL"
      exit 1
    fi
  fi

  # Check for JWT_SECRET = "something real" (not placeholder)
  JWT=$(echo "$CONTENT" | grep -E 'JWT_SECRET\s*[=:]\s*["'"'"']' | grep -v 'your-strong' | grep -v 'replace-with' | grep -v 'your-jwt' || true)
  if [ -n "$JWT" ]; then
    echo "❌ ERROR: Possible real JWT_SECRET in $FILE"
    echo "   $JWT"
    exit 1
  fi

  # Check for hardcoded password patterns in new/modified lines
  PASS=$(echo "$CONTENT" | grep -E '(password|passwd|pwd)\s*[=:]\s*["'"'"']' | grep -v 'process\.env' | grep -v 'import\.meta' | grep -v 'getEnv' | grep -v 'getAdminInitialPassword' | grep -v 'generateRandomPassword' | grep -v 'hashPassword' | grep -v 'comparePassword' | grep -v 'currentPassword' | grep -v 'newPassword' | grep -v 'mustChangePassword' || true)
  if [ -n "$PASS" ]; then
    echo "⚠️  WARNING: Possible hardcoded password in $FILE"
    echo "   $PASS"
    echo "   (Review manually. Use generateRandomPassword() instead.)"
  fi
done

echo "✅ Secrets check passed"
exit 0
